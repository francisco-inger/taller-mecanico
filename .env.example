# ── Aplicación ───────────────────────────────────────────────
NODE_ENV=production
PORT=10000

# ── Base de datos (PostgreSQL) ───────────────────────────────
# En Render, usa la URL que te proporciona la base de datos PostgreSQL
DATABASE_URL=postgresql://usuario:password@host:5000/base_de_datos

# ── JWT (Autenticación) ──────────────────────────────────────
JWT_SECRET=tu_secreto_seguro_aqui
JWT_EXPIRES_IN=8h

# ── Email (Nodemailer) ───────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Frontend URL (CORS) ──────────────────────────────────────
FRONTEND_URL=https://tu-frontend.onrender.com
