# ─────────────────────────────────────────────────────────────
# .env.example — Copiar a .env y completar los valores
# Sistema de Órdenes de Servicio — Taller Mecánico
# ─────────────────────────────────────────────────────────────

# ── Aplicación ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Base de datos (PostgreSQL) ───────────────────────────────
DATABASE_URL=postgresql://taller_user:taller_pass@localhost:5432/taller_db

# Para Docker usar:
# DATABASE_URL=postgresql://taller_user:taller_pass@postgres:5432/taller_db

POSTGRES_USER=taller_user
POSTGRES_PASSWORD=taller_pass
POSTGRES_DB=taller_db

# ── JWT (Autenticación) ──────────────────────────────────────
# IMPORTANTE: Cambiar en producción por una clave segura de al menos 32 caracteres
JWT_SECRET=supersecreto_cambiar_en_produccion_xK9mN2pQ7vR4sT1w
JWT_EXPIRES_IN=8h

# ── Email (Nodemailer) ───────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=taller@gmail.com
SMTP_PASS=tu_contraseña_de_aplicacion

# ── Frontend URL (CORS) ──────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Nota sobre Keycloak ──────────────────────────────────────
# Para producción, migrar a Keycloak con:
# KEYCLOAK_URL=http://localhost:8080
# KEYCLOAK_REALM=taller-mecanico
# KEYCLOAK_CLIENT_ID=taller-backend
# KEYCLOAK_CLIENT_SECRET=xxxxx
