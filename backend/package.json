{
  "name": "taller-mecanico-backend",
  "version": "1.0.0",
  "description": "Sistema de Órdenes de Servicio para Taller Mecánico — Backend",
  "author": "Francisco R. Diaz",
  "license": "MIT",
  "main": "src/interfaces/http/server.js",
  "scripts": {
    "dev": "nodemon src/interfaces/http/server.js",
    "start": "node src/interfaces/http/server.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:arch": "jest tests/arch --runInBand",
    "test:domain": "jest tests/domain --runInBand",
    "arch:check": "depcruise src --config .dependency-cruiser.cjs",
    "arch:report": "depcruise src --config .dependency-cruiser.cjs --output-type archi",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:seed": "node prisma/seed.js",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.13",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "dependency-cruiser": "^16.3.3",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/interfaces/**"
    ]
  }
}
